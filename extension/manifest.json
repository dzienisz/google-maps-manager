{
  "manifest_version": 3,
  "name": "Google Maps Manager",
  "version": "1.0.0",
  "description": "Zarządzaj zapisanymi miejscami w Google Maps – duplikaty, listy, eksport",
  "permissions": ["storage", "sidePanel", "scripting", "tabs", "activeTab"],
  "host_permissions": [
    "https://www.google.com/maps/*",
    "https://maps.google.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.google.com/maps/*", "https://maps.google.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "side_panel": {
    "default_path": "panel.html"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Google Maps Manager",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["inject.js"],
      "matches": ["https://www.google.com/maps/*", "https://maps.google.com/*"]
    }
  ]
}
